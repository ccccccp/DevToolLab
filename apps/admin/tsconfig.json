{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": [
      "./cloudflare-env.d.ts"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "jsx": "preserve",
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
